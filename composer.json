{
  "name": "memran/marwa-db",
  "description": "Lightweight, framework-agnostic PHP database toolkit: connections, query builder, ORM, schema, migrations, seeders, debug panel.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "ext-pdo": "*",
    "fakerphp/faker": "^1.23",
    "memran/marwa-debugbar": "dev-main",
    "memran/marwa-error-handler": "dev-main",
    "memran/marwa-logger": "dev-main",
    "symfony/console": "^7.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5.62"
  },
  "autoload": {
    "psr-4": {
      "Marwa\\DB\\": "src/"
    },
    "files": [
      "src/Support/Helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Marwa\\DB\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist",
    "test:unit": "phpunit -c phpunit.xml.dist --testsuite Unit",
    "test:integration": "phpunit -c phpunit.xml.dist --testsuite Integration",
    "lint": "php -l $(git ls-files '*.php')",
    "analyze": "phpstan analyse --configuration=phpstan.neon --memory-limit=512M",
    "ci": [
      "@lint",
      "@analyze",
      "@test"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
